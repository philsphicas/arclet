root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab

# Continuation lines in Dockerfile RUN steps are conventionally aligned
# to the previous line's content (e.g. one space before `&&`), not on a
# 4-space grid, so don't enforce indent here.
[Dockerfile]
indent_size = unset

# Markdown contains ASCII tables, indented code blocks, and other
# content where strict padding rules are inappropriate.
[*.md]
indent_size = unset
trim_trailing_whitespace = false

# The dependabot auto-merge workflow uses an embedded JavaScript literal
# (`script: |`) and column-aligned boolean continuation under `if: >`,
# both of which break the YAML 2-space rule. The shape mirrors the
# pattern used in actions/github-script docs, so we exempt this file.
[.github/workflows/dependabot-auto-merge.yml]
indent_size = unset
